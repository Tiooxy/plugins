-- ==========================================
-- FETCH & API LOGIC
-- ==========================================
local function getAssetInfo(assetId)
    local success, response = pcall(function()
        if type(request) == "function" then
            return request({Url = "https://economy.roblox.com/v2/assets/" .. assetId .. "/details", Method = "GET"}).Body
        else
            return game:HttpGet("https://economy.roblox.com/v2/assets/" .. assetId .. "/details")
        end
    end)
    if success and response then
        local data = HttpService:JSONDecode(response)
        return {id = assetId, name = data.Name or "Model", icon = assetId}
    end
    return {id = assetId, name = "Model", icon = assetId}
end

local function fetchModels(keyword)
    local url = "https://apis.roblox.com/toolbox-service/v1/marketplace/10?limit=55&keyword=" .. HttpService:UrlEncode(keyword)
    local success, response = pcall(function()
        if type(request) == "function" then
            return request({Url = url, Method = "GET"}).Body
        else
            return game:HttpGet(url)
        end
    end)
    
    if success and response then
        local decoded = HttpService:JSONDecode(response)
        if decoded and decoded.data then
            local res = {}
            for i, item in ipairs(decoded.data) do
                if item.id then
                    table.insert(res, getAssetInfo(item.id))
                end
                if i % 6 == 0 then task.wait() end 
            end
            return res
        end
    end
    return nil
end

local function fetchAudio(keyword)
    local params = Instance.new("AudioSearchParams")
    params.SearchKeyword = keyword
    local success, res = pcall(function() return AssetService:SearchAudioAsync(params) end)
    
    if success and res then
        local list = {}
        for i, v in ipairs(res:GetCurrentPage()) do 
            table.insert(list, {id = v.Id, name = v.Title}) 
            if i % 6 == 0 then task.wait() end
        end
        return list
    end
    return nil
end

