-- EXECUTE SEARCH LOGIC
-- ==========================================
local function doSearch()
    dropMenu.Visible = false
    sideBox.Visible = false
    loadingLabel.Visible = true
    gridArea.Visible = false
    task.wait(0.1) 
    
    local res
    if searchMode == "Model" then
        res = fetchModels(searchBox.Text)
    elseif searchMode == "Audio" then
        res = fetchAudio(searchBox.Text)
    end
    
    displayGrid(res, searchMode)
    loadingLabel.Visible = false
    gridArea.Visible = true
end

searchBtn.MouseButton1Click:Connect(doSearch)
searchBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then doSearch() end
end)

-- ==========================================
-- SYNC DRAG SYSTEM
-- ==========================================
local function enableDrag(frame, handle)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            frame.Position = newPos
            sideBox.Position = newPos + UDim2.new(0, 270, 0, 100)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end

