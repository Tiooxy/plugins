local function createActionAxis(axisName, parent)
	local frame = Instance.new("Frame", parent); frame.Size = UDim2.new(1,0,0,26); frame.BackgroundTransparency=1
	local btnMinus = makeBtn("-", frame); btnMinus.Size = UDim2.new(0.2,0,1,0)
	local lbl = makeBtn(axisName .. " (Move)", frame); lbl.Size = UDim2.new(0.56,0,1,0); lbl.Position = UDim2.new(0.22,0,0,0)
	local btnPlus = makeBtn("+", frame); btnPlus.Size = UDim2.new(0.2,0,1,0); btnPlus.Position = UDim2.new(0.8,0,0,0)
	table.insert(axisLabels, {Label = lbl, Axis = axisName})
	
	local function doAction(sign)
		local step = EditorState.SizeStep * sign; local tool = EditorState.PartTool
		if tool == "Select" or tool == "Create" then tool = "Move" end
		for _, p in ipairs(selectedParts) do
