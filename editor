local function applyTerrainBrush(hitP)
	local tMat = (EditorState.TerrainTool == "Erase") and Enum.Material.Air or EditorState.Material
	local s, t = EditorState.BrushSize, math.max(0.1, EditorState.Thickness)
	local tShape = EditorState.TerrainShape
	local mS = string.match(tostring(tMat), "Enum.Material.(.+)")
	
	if EditorState.TerrainTool == "Island" then hitP = Vector3.new(hitP.X, hitP.Y + 30 + (t/2), hitP.Z) end
	
	if tShape == "Block" then
		local cf = CFrame.new(hitP); local sz = (EditorState.TerrainTool == "Island") and Vector3.new(s, t, s) or Vector3.new(s, t, s)
		Terrain:FillBlock(cf, sz, tMat)
		table.insert(terrainCodes, string.format("Terrain:FillBlock(CFrame.new(%.1f,%.1f,%.1f), Vector3.new(%.1f,%.1f,%.1f), Enum.Material.%s)", cf.X, cf.Y, cf.Z, sz.X, sz.Y, sz.Z, mS))
	elseif tShape == "Ball" then
		local radius = s / 2
		Terrain:FillBall(hitP, radius, tMat)
		table.insert(terrainCodes, string.format("Terrain:FillBall(Vector3.new(%.1f,%.1f,%.1f), %.1f, Enum.Material.%s)", hitP.X, hitP.Y, hitP.Z, radius, mS))
	elseif tShape == "Cone" then
		spawnConeIsland(hitP, s, t, tMat)
		table.insert(terrainCodes, string.format("spawnConeIsland(Vector3.new(%.1f,%.1f,%.1f), %.1f, %.1f, Enum.Material.%s)", hitP.X, hitP.Y, hitP.Z, s, t, mS))
	end
end

