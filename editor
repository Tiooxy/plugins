-- 9. GENERATE SCRIPT & SAVE LOGIC
-- ==========================================
local function getGeneratedScript()
	local s = "local Terrain = workspace.Terrain\ntask.wait(1)\n\n" 
	
	local tCodesStr = table.concat(terrainCodes, "\n")
	if string.find(tCodesStr, "spawnConeIsland") then
		local coneFuncStr = [[
local function spawnConeIsland(centerPosition, radius, thickness, baseMaterial)
	local seed = tick() + math.random(1,1000)
	local STEP = math.clamp(math.floor(radius / 15), 2, 6)
	
	local trueThick = math.max(0.1, thickness)
	local SCALE_Y = math.clamp(trueThick / radius, 0.1, 5)
	local BATAS_ATAS = trueThick * 0.2
	local BATAS_BAWAH = -trueThick * 0.8
	local KASAR = radius / 2
	local NOISE_POWER = radius / 4
	local isAir = (baseMaterial == Enum.Material.Air)

	for x = -radius, radius, STEP do
		if x % (STEP * 5) == 0 then task.wait() end
		for y = BATAS_BAWAH, BATAS_ATAS, STEP do
			for z = -radius, radius, STEP do
				local pos = Vector3.new(x + centerPosition.X, y + centerPosition.Y, z + centerPosition.Z)
				local offset = pos - centerPosition
				local jarak = Vector3.new(offset.X, offset.Y * (1 / SCALE_Y), offset.Z).Magnitude
				local noise = math.noise((x/KASAR) + seed, (y/KASAR) + seed, (z/KASAR) + seed) * NOISE_POWER

				if jarak + noise <= radius then
					local material = baseMaterial
					if not isAir then
						if y >= BATAS_ATAS - (STEP*1.5) then material = baseMaterial
						elseif y <= BATAS_BAWAH + (STEP*2.5) then material = Enum.Material.Rock
						else material = math.random() > 0.5 and Enum.Material.Ground or Enum.Material.Rock end
					end
					Terrain:FillBlock(CFrame.new(pos), Vector3.new(STEP, STEP, STEP), material)
				end
			end
		end
	end
end
]]
		s = s .. "-- [ PROCEDURAL FUNCTIONS ] --\n" .. coneFuncStr .. "\n"
	end

	s = s .. "-- [ COLORS ] --\n" 
	for mat, col in pairs(modifiedColors) do local mS = string.match(tostring(mat), "Enum.Material.(.+)"); s = s .. string.format("Terrain:SetMaterialColor(Enum.Material.%s, Color3.fromRGB(%d, %d, %d))\n", mS, math.round(col.R*255), math.round(col.G*255), math.round(col.B*255)) end
	
	s = s .. "\n-- [ TERRAIN ] --\n" .. tCodesStr .. "\n\n-- [ PARTS ] --\n"
	for _, p in ipairs(mapFolder:GetChildren()) do
		local rot, mS = p.Orientation, string.match(tostring(p.Material), "Enum.Material.(.+)")
		local pC = string.format("local p = Instance.new('%s'); ", p.ClassName)
		if p:IsA("Part") then pC = pC .. string.format("p.Shape = Enum.PartType.%s; ", string.match(tostring(p.Shape), "Enum.PartType.(.+)")) end
		pC = pC .. string.format("p.Size = Vector3.new(%.1f,%.1f,%.1f); p.CFrame = CFrame.new(%.1f,%.1f,%.1f) * CFrame.Angles(math.rad(%.1f),math.rad(%.1f),math.rad(%.1f)); p.Material = Enum.Material.%s; p.Transparency = %.1f; p.Anchored = %s; p.CanCollide = %s; p.Parent = workspace", p.Size.X, p.Size.Y, p.Size.Z, p.Position.X, p.Position.Y, p.Position.Z, rot.X, rot.Y, rot.Z, mS, p.Transparency, tostring(p.Anchored), tostring(p.CanCollide))
		s = s .. pC .. "\n"
	end
	
	return s
end

