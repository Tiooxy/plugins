-- 2. PROCEDURAL CONE ISLAND GENERATOR
-- ==========================================
local function spawnConeIsland(centerPosition, radius, thickness, baseMaterial)
	task.spawn(function()
		local seed = tick() + math.random(1, 1000)
		local STEP = math.clamp(math.floor(radius / 15), 2, 6) 
		
		local trueThick = math.max(0.1, thickness)
		local SCALE_Y = math.clamp(trueThick / radius, 0.1, 5) 
		local BATAS_ATAS = trueThick * 0.2
		local BATAS_BAWAH = -trueThick * 0.8
		
		local KASAR = radius / 2
		local NOISE_POWER = radius / 4
		
		local isAir = (baseMaterial == Enum.Material.Air)

		for x = -radius, radius, STEP do
			if x % (STEP * 5) == 0 then task.wait() end 
			for y = BATAS_BAWAH, BATAS_ATAS, STEP do
				for z = -radius, radius, STEP do
					local pos = Vector3.new(x + centerPosition.X, y + centerPosition.Y, z + centerPosition.Z)
					local offset = pos - centerPosition
					local jarak = Vector3.new(offset.X, offset.Y * (1 / SCALE_Y), offset.Z).Magnitude
					local noise = math.noise((x/KASAR) + seed, (y/KASAR) + seed, (z/KASAR) + seed) * NOISE_POWER

					if jarak + noise <= radius then
						local material = baseMaterial
						if not isAir then
							if y >= BATAS_ATAS - (STEP*1.5) then
								material = baseMaterial
							elseif y <= BATAS_BAWAH + (STEP*2.5) then
								material = Enum.Material.Rock
							else
								material = math.random() > 0.5 and Enum.Material.Ground or Enum.Material.Rock
							end
						end
						Terrain:FillBlock(CFrame.new(pos), Vector3.new(STEP, STEP, STEP), material)
					end
				end
			end
		end
	end)
end

