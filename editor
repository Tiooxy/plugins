	initialStates = {}
	for _, p in ipairs(selectedParts) do initialStates[p] = {cf = p.CFrame, sz = p.Size} end
end)
scaleHandles.MouseDrag:Connect(function(face, dist)
	local axis = Vector3.FromNormalId(face)
	for p, st in pairs(initialStates) do
		if p and p.Parent then
			local newSize = st.sz + Vector3.new(math.abs(axis.X), math.abs(axis.Y), math.abs(axis.Z)) * dist
			if newSize.X > 0.5 and newSize.Y > 0.5 and newSize.Z > 0.5 then p.Size = newSize; p.CFrame = st.cf * CFrame.new(axis * dist / 2) end
		end
	end
end)

