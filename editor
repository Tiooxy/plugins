	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isPaintingTerrain = false
		lastPaintPos = nil
		
		if isScreenSelecting then
			isScreenSelecting = false
			dragBox.Visible = false
			
			local currentPos = Vector2.new(input.Position.X, input.Position.Y)
			local minX = math.min(screenStartPos.X, currentPos.X)
			local maxX = math.max(screenStartPos.X, currentPos.X)
			local minY = math.min(screenStartPos.Y, currentPos.Y)
			local maxY = math.max(screenStartPos.Y, currentPos.Y)
			
			if (maxX - minX) > 10 and (maxY - minY) > 10 then
