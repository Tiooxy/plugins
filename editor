local function makeDrag(g, a, t)
	local dS, sP, iD = nil, nil, false
	a.InputBegan:Connect(function(i) 
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dS = i.Position; sP = g.Position; iD = false end 
